(define (problem LIBERO_Coffee_Table_Manipulation)
  (:domain robosuite)
  (:language Prepare a serving arrangement with sauces and drinks)
    (:regions
      (basket_init_region
          (:target coffee_table)
          (:ranges (
              (-0.13999999999999999 0.53 -0.09999999999999999 0.5700000000000001)
            )
          )
          (:yaw_rotation (
              (3.141592653589793 3.141592653589793)
            )
          )
      )
      (cookies_init_region
          (:target coffee_table)
          (:ranges (
              (-0.16115932842892908 0.06473974597444605 -0.12115932842892908 0.10473974597444606)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (tomato_sauce_init_region
          (:target coffee_table)
          (:ranges (
              (-0.08588141447324492 -0.08441635349968928 -0.04588141447324491 -0.04441635349968927)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (table_region
          (:target coffee_table)
          (:ranges (
              (-2 -2 2 2)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (contain_region
          (:target basket_1)
      )
    )

  (:fixtures
    coffee_table - coffee_table
  )

  (:objects
    basket_1 - basket
    cookies_1 - cookies
    tomato_sauce_1 - tomato_sauce
  )

  (:obj_of_interest
    cookies_1
    basket_1
    tomato_sauce_1
  )

  (:init
    (On basket_1 coffee_table_basket_init_region)
    (On cookies_1 coffee_table_cookies_init_region)
    (On tomato_sauce_1 coffee_table_tomato_sauce_init_region)
  )

  (:goal
    (And 
        (In cookies_1 basket_1_contain_region) 
        (In tomato_sauce_1 basket_1_contain_region)
    )
  )

)