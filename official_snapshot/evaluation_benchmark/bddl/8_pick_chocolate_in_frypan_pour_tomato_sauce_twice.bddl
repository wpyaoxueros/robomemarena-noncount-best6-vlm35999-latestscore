(define (problem LIBERO_Coffee_Table_Manipulation)
  (:domain robosuite)
  (:language Prepare the coffee serving area by organizing tableware and cleaning out any residual liquid)
    (:regions
      (bowl_drainer_init_region
          (:target coffee_table)
          (:ranges (
              (-0.1575 0.53 -0.11750000000000001 0.5700000000000001)
            )
          )
          (:yaw_rotation (
              (3.141592653589793 3.141592653589793)
            )
          )
      )
      (chocolate_pudding_init_region
          (:target coffee_table)
          (:ranges (
              (-0.15 -0.20 -0.10 -0.15)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (tomato_sauce_init_region
          (:target coffee_table)
          (:ranges (
              (0.05 -0.20 0.10 -0.15)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (frypan_init_region
          (:target coffee_table)
          (:ranges (
              (-0.02 0.10 0.02 0.13)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (table_region
          (:target coffee_table)
          (:ranges (
              (-2 -2 2 2)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (left_region
          (:target bowl_drainer_1)
      )
      (right_region
          (:target bowl_drainer_1)
      )
      (contain_region
          (:target frypan_1)
      )
    )

  (:fixtures
    bowl_drainer_1 - bowl_drainer
    coffee_table - coffee_table
  )

  (:objects
    chocolate_pudding_1 - chocolate_pudding
    tomato_sauce_1 - tomato_sauce
    frypan_1 - chefmate_8_frypan
  )

  (:obj_of_interest
    bowl_drainer_1
    chocolate_pudding_1
    tomato_sauce_1
    frypan_1
  )

  (:init
    (On bowl_drainer_1 coffee_table_bowl_drainer_init_region)
    (On chocolate_pudding_1 coffee_table_chocolate_pudding_init_region)
    (On tomato_sauce_1 coffee_table_tomato_sauce_init_region)
    (On frypan_1 coffee_table_frypan_init_region)
  )

  (:goal
    (And 
        (In chocolate_pudding_1 frypan_1_contain_region)
        (Or 
            (In tomato_sauce_1 bowl_drainer_1_left_region)
            (In tomato_sauce_1 bowl_drainer_1_right_region)
        )
    )
  )
)