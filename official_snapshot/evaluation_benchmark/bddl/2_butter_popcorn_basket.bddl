(define (problem LIBERO_Coffee_Table_Manipulation)
  (:domain robosuite)
  (:language Prepare a serving arrangement with butter, popcorn and basket)
    (:regions
      (basket_init_region
          (:target coffee_table)
          (:ranges (
              (-0.04 0.18 0.0 0.22)
            )
          )
          (:yaw_rotation (
              (3.141592653589793 3.141592653589793)
            )
          )
      )
      (butter_init_region
          (:target coffee_table)
          (:ranges (
              (-0.04 -0.04 0.0 0.0)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (popcorn_init_region
          (:target coffee_table)
          (:ranges (
              (-0.04 -0.26 0.0 -0.22)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (table_region
          (:target coffee_table)
          (:ranges (
              (-2 -2 2 2)
            )
          )
          (:yaw_rotation (
              (0.0 0.0)
            )
          )
      )
      (contain_region
          (:target basket_1)
      )
    )

  (:fixtures
    coffee_table - coffee_table
  )

  (:objects
    basket_1 - basket
    butter_1 - butter
    popcorn_1 - popcorn
  )

  (:obj_of_interest
    butter_1
    basket_1
    popcorn_1
  )

  (:init
    (On basket_1 coffee_table_basket_init_region)
    (On butter_1 coffee_table_butter_init_region)
    (On popcorn_1 coffee_table_popcorn_init_region)
  )

  (:goal
    (And
        (In butter_1 basket_1_contain_region)
        (In popcorn_1 basket_1_contain_region)
    )
  )

)
